# Bu dosyayı '.env' olarak kopyalayıp doldur. '.env*' gitignore'dadır (commit EDİLMEZ).
# Sırları asla CLAUDE.md / .mcp.json / settings.json içine yazma — env üzerinden ver.

# --- GitHub MCP (.mcp.json → github) ---
GITHUB_PERSONAL_ACCESS_TOKEN=

# --- Veritabanı (.mcp.json → postgres + uygulama) ---
DATABASE_URL=postgresql://user:pass@localhost:5432/app

# --- Bildirim (hooks/notify.sh — opsiyonel; set değilse sessiz) ---
SLACK_WEBHOOK_URL=

# --- .NET ---
ASPNETCORE_ENVIRONMENT=Development
