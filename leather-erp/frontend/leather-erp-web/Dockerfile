# --- Build aşaması ---
FROM node:22-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

# --- Çalışma aşaması (nginx) ---
FROM nginx:alpine AS final
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist/leather-erp-web/browser /usr/share/nginx/html
EXPOSE 80
